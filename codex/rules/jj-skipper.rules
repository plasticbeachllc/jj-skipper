# jj-skipper: Block git commands in jj repositories.
# Installed to ~/.codex/rules/jj-skipper.rules

prefix_rule(
    pattern = ["git"],
    decision = "forbidden",
    justification = "This is a jj repository. Use jj commands instead of git. For example: git status → jj st, git commit → jj commit -m 'msg', git push → jj git push. See the jj-guide skill for full mappings.",
    match = [
        "git status",
        "git commit -m 'test'",
        "git push origin main",
        "git checkout -b feature",
        "git diff",
        "git log",
        "git add .",
        "git stash",
        "git rebase main",
        "git reset --hard",
    ],
    not_match = [
        "jj git push",
        "jj st",
        "jj commit -m 'test'",
        "jj log",
    ],
)
